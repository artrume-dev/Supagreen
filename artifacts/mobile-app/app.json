{
  "expo": {
    "name": "Recipe Genie",
    "slug": "recipe-genie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "recipegenie",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1710"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.recipegenie.app",
      "buildNumber": "1",
      "minimumOsVersion": "16.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Recipe Genie uses your location to personalise seasonal ingredients and suggest what's available near you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F1710"
      },
      "package": "com.recipegenie.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
